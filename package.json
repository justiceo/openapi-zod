{
  "name": "openapi-zod",
  "version": "0.1.0",
  "description": "Convert OpenAPI 3.x documents to Zod 4 validators and route metadata.",
  "license": "MIT",
  "author": "Justice O.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justiceo/openapi-zod.git"
  },
  "bugs": {
    "url": "https://github.com/justiceo/openapi-zod/issues"
  },
  "homepage": "https://github.com/justiceo/openapi-zod#readme",
  "keywords": [
    "openapi",
    "zod",
    "typescript",
    "codegen",
    "schema",
    "validation"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "openapi-zod": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "npm run build && node scripts/serve-demo.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm test && npm run pack:dry-run",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
